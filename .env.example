PORT=3001
API_KEY=

# Chain to index (100=Gnosis, 10200=Chiado)
CHAIN_ID=100

# Beacon node URL for each supported chain
BEACON_URL_100=https://rpc-gbc.gnosischain.com
BEACON_URL_10200=https://rpc-gbc.chiadochain.net

LOG_LEVEL=info

# How often to do a full validator re-fetch (catches BLS-to-execution changes).
# Balance-only sync runs every epoch. Full sync runs every N epochs.
FULL_SYNC_EVERY_N_EPOCHS=10
